# Bunnyx Integration Test

## Section

Full API verification against the real bunny.net API. Run all cells top to bottom. Idempotent — safe to run multiple times.

## Setup

```elixir
Mix.install([{:bunnyx, path: Path.join(__DIR__, "..")}])

api_key = System.fetch_env!("LB_BUNNY_API_KEY")
client = Bunnyx.new(api_key: api_key, receive_timeout: 30_000)

# Unique suffix per run — avoids collisions with zones still being deleted
run_id = System.system_time(:second) |> rem(100_000) |> to_string()

IO.puts("Client ready (run_id: #{run_id})")
:ok
```

## Cleanup previous run

```elixir
# Helper to get items from either flat list or paginated response
items = fn
  list when is_list(list) -> list
  %{items: items} -> items
end

IO.puts("  Listing storage zones...")
{:ok, all_sz} = Bunnyx.StorageZone.list(client)

cleanup = fn name, result ->
  case result do
    {:ok, _} -> IO.puts("  Deleted #{name}")
    {:error, e} -> IO.puts("  Failed to delete #{name}: #{e.message}")
  end
end

stale_sz = Enum.filter(items.(all_sz), &String.starts_with?(&1.name, "bunnyx-int-"))
IO.puts("  Found #{length(stale_sz)} storage zone(s) to clean up")

for z <- stale_sz do
  IO.puts("  Deleting storage zone #{z.name}...")
  cleanup.(z.name, Bunnyx.StorageZone.delete(client, z.id))
end

safe_list_and_delete = fn label, list_fn, name_fn, delete_fn ->
  IO.puts("  Listing #{label}...")

  case list_fn.() do
    {:ok, result} ->
      all = items.(result)
      stale = Enum.filter(all, fn z -> String.starts_with?(name_fn.(z), "bunnyx-int-") end)
      IO.puts("  Found #{length(stale)} #{label} to clean up (out of #{length(all)} total)")

      for z <- stale do
        IO.puts("  Deleting: #{name_fn.(z)}...")
        cleanup.(name_fn.(z), delete_fn.(z))
      end

    {:error, e} ->
      IO.puts("  Skipped #{label} cleanup (#{e.message})")
  end
end

# Don't use search: param — bunny.net's pull zone search causes 504s.
# List all and filter client-side instead.

safe_list_and_delete.("pull zones",
  fn -> Bunnyx.PullZone.list(client) end,
  fn z -> z.name end,
  fn z -> Bunnyx.PullZone.delete(client, z.id) end
)

safe_list_and_delete.("DNS zones",
  fn -> Bunnyx.DnsZone.list(client) end,
  fn z -> z.domain end,
  fn z -> Bunnyx.DnsZone.delete(client, z.id) end
)

safe_list_and_delete.("video libraries",
  fn -> Bunnyx.VideoLibrary.list(client) end,
  fn lib -> lib.name end,
  fn lib -> Bunnyx.VideoLibrary.delete(client, lib.id) end
)

IO.puts("✓ Cleanup done")
```

## Part 1: Reference Data

### Countries

```elixir
{:ok, countries} = Bunnyx.Country.list(client)
true = is_list(countries)
true = length(countries) > 100
%{name: name, iso_code: code} = hd(countries)

IO.puts("✓ Countries: #{length(countries)} entries (first: #{name} / #{code})")
```

### Regions

```elixir
{:ok, regions} = Bunnyx.Region.list(client)
true = length(regions) > 0
%{name: name, region_code: code} = hd(regions)

IO.puts("✓ Regions: #{length(regions)} entries (first: #{name} / #{code})")
```

### Statistics

```elixir
{:ok, stats} = Bunnyx.Statistics.get(client)
true = is_integer(stats.total_bandwidth_used)

IO.puts("✓ Statistics: bandwidth #{stats.total_bandwidth_used}, cache hit rate #{stats.cache_hit_rate}")
```

### Billing

```elixir
{:ok, billing} = Bunnyx.Billing.details(client)
true = is_number(billing.balance)

IO.puts("✓ Billing: balance #{billing.balance}")
```

